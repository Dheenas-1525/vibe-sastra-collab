# ── vibe-ai server configuration ──────────────────────────────────────────────

# Secret used to authenticate webhook calls sent back to the ViBe backend
WEBHOOK_SECRET=vibe-local-secret

# URL the vibe-ai server calls to report task completion back to the backend
WEBHOOK_URL=http://vibe-backend:8080/api/genAI/webhook

# ── LLM — GPU server running vLLM ─────────────────────────────────────────────
# Replace YOUR_GPU_SERVER_IP with your GPU server's actual IP address.
# vLLM default port is 8000.
VLLM_BASE_URL=http://YOUR_GPU_SERVER_IP:8000/v1

# ── Object Storage — MinIO ────────────────────────────────────────────────────
# Credentials must match MINIO_ROOT_USER / MINIO_ROOT_PASSWORD in docker-compose.yml.
GCLOUD_BUCKET_NAME=vibe-aiserver-data
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=vibeadmin
MINIO_SECRET_KEY=change-this-strong-password
MINIO_PUBLIC_URL=http://minio:9000

# ── Server ────────────────────────────────────────────────────────────────────
PORT=9017
