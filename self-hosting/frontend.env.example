# ══════════════════════════════════════════════════════════════════════════════
# ViBe Frontend — Environment Variables
#
# HOW TO USE:
#   1. Copy this file and name it:  .env  (inside the  frontend/  directory)
#      The final path should be:   vibe/frontend/.env
#   2. Fill in every value
#   3. IMPORTANT: These values are baked into the app at BUILD TIME.
#      If you change them, you must rebuild the frontend (docker-compose build frontend).
#
# See self-hosting/DEPLOYMENT_GUIDE.md for where to get each value.
# ══════════════════════════════════════════════════════════════════════════════


# ── FIREBASE CONFIGURATION ────────────────────────────────────────────────────
# Get all of these from: Firebase Console → Your Project → Project Settings
#                         → Your Apps → Web App → SDK Setup and Configuration

# [REQUIRED] Firebase Web API Key
VITE_FIREBASE_API_KEY=

# [REQUIRED] Firebase Auth Domain (format: your-project-id.firebaseapp.com)
VITE_FIREBASE_AUTH_DOMAIN=

# [REQUIRED] Firebase Project ID
VITE_FIREBASE_PROJECT_ID=

# [REQUIRED] Firebase Storage Bucket (format: your-project-id.appspot.com)
VITE_FIREBASE_STORAGE_BUCKET=

# [REQUIRED] Firebase Messaging Sender ID (a numeric value)
VITE_FIREBASE_MESSAGING_SENDER_ID=

# [REQUIRED] Firebase App ID (format: 1:XXXXXXXXXX:web:XXXXXXXXXX)
VITE_FIREBASE_APP_ID=

# [OPTIONAL] Firebase Measurement ID for Google Analytics (format: G-XXXXXXXXXX)
VITE_FIREBASE_MEASUREMENT_ID=


# ── BACKEND API URL ───────────────────────────────────────────────────────────

# [REQUIRED] The full URL of your backend API (where the browser will send requests).
#
# IMPORTANT: This is the URL that your users' BROWSERS use to reach the backend.
#            It must be publicly accessible.
#
# If running locally:
#   VITE_BASE_URL=http://localhost:8080/api
#
# If on a server (replace with your server's IP or domain):
#   VITE_BASE_URL=http://YOUR_SERVER_IP:8080/api
#   VITE_BASE_URL=https://api.yourdomain.com/api
#
VITE_BASE_URL=http://localhost:8080/api


# ── RECAPTCHA (Optional) ──────────────────────────────────────────────────────

# [OPTIONAL] Google reCAPTCHA Site Key (the PUBLIC key, different from the secret key).
# Get from: console.cloud.google.com → Security → reCAPTCHA
# Leave empty if IS_RECAPTCHA_ENABLED=false in your backend.env
VITE_RECAPTCHA_SITE_KEY=
