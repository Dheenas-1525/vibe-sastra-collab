# ══════════════════════════════════════════════════════════════════════════════
# ViBe Backend — Environment Variables
#
# HOW TO USE:
#   1. Copy this file and name it:  backend.env  (in the root of the project)
#   2. Fill in every value marked as REQUIRED
#   3. Optionally fill in OPTIONAL values for extra features
#
# See self-hosting/DEPLOYMENT_GUIDE.md for where to get each value.
# ══════════════════════════════════════════════════════════════════════════════


# ── SERVER ────────────────────────────────────────────────────────────────────

# [REQUIRED] Runtime environment. Always use "production" for self-hosted.
NODE_ENV=production

# [REQUIRED] Port the backend listens on inside the container. Do not change.
APP_PORT=8080

# [REQUIRED] The public URL of your backend server (no trailing slash).
# If running locally:  http://localhost:8080
# If on a server:      http://YOUR_SERVER_IP:8080
# If using a domain:   https://api.yourdomain.com
APP_URL=http://localhost:8080

# [REQUIRED] Comma-separated list of URLs allowed to call this API (CORS).
# Add your frontend URL here. No trailing slashes.
# Example: https://yourdomain.com,http://localhost:3000
APP_ORIGINS=http://localhost:3000

# [REQUIRED] Prefix for all API routes. Do not change this.
APP_ROUTE_PREFIX=/api

# [REQUIRED] Which modules to load. Use "all" to run the full application.
APP_MODULE=all

# [REQUIRED] The URL of your frontend (used in email links).
# This is where teachers log in. Example: https://yourdomain.com/teacher
FRONTEND_URL=http://localhost:3000/teacher

# [REQUIRED] A strong password for the admin panel. Change this!
ADMIN_PASSWORD=change_this_to_a_strong_password


# ── DATABASE ──────────────────────────────────────────────────────────────────

# [REQUIRED] MongoDB connection string.
#
# If using MongoDB Atlas:
#   mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority&appName=<appname>
#
# If using local MongoDB (docker-compose with mongodb service):
#   mongodb://vibeadmin:change_this_strong_password@vibe-mongodb:27017/vibe?authSource=admin
#
DB_URL=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@YOUR_CLUSTER.mongodb.net/?retryWrites=true&w=majority&appName=vibe

# [REQUIRED] The name of the database. Keep as "vibe" unless you have a reason to change.
DB_NAME=vibe


# ── AI / ANTHROPIC (Claude) ───────────────────────────────────────────────────

# [REQUIRED] The Anthropic Claude model to use for AI features.
ANTHROPIC_MODEL=claude-sonnet-4-20250514

# [REQUIRED] Your Anthropic API key. Get it from console.anthropic.com
# Format: sk-ant-api03-...
ANTHROPIC_CRED=sk-ant-api03-YOUR_KEY_HERE


# ── reCAPTCHA ─────────────────────────────────────────────────────────────────

# [REQUIRED] Secret key from Google reCAPTCHA. Get from console.cloud.google.com
RECAPTCHA_SECRET_KEY=YOUR_RECAPTCHA_SECRET_KEY

# [REQUIRED] Set to "true" to enforce reCAPTCHA on sign-up.
# Set to "false" to disable (useful for testing).
IS_RECAPTCHA_ENABLED=true


# ── MONITORING (Optional) ─────────────────────────────────────────────────────

# [OPTIONAL] Sentry DSN for error tracking. Leave empty to disable.
# Get from sentry.io → Settings → Projects → Client Keys (DSN)
SENTRY_DSN=


# ── DATABASE BACKUP (Optional) ────────────────────────────────────────────────

# [OPTIONAL] Set to "true" to enable automatic daily backups to Google Cloud Storage.
# Requires GCP credentials configured. Set to "false" to disable.
ENABLE_DB_BACKUP=false

# [OPTIONAL] GCP Storage bucket name for database backups.
# Only needed if ENABLE_DB_BACKUP=true
GCP_BACKUP_BUCKET=

# [OPTIONAL] GCP Storage bucket name for storing user submissions.
# Only needed if ENABLE_DB_BACKUP=true
GCP_BACKUP_ACTIVITY_BUCKET=


# ── TAILSCALE / AI SERVER (Optional — Advanced) ───────────────────────────────
# These are only needed if you are running the self-hosted AI server (vibe-ai).
# Skip this section if you are only using the Anthropic Claude API above.

# [OPTIONAL] Tailscale auth key for connecting to the private AI server network.
TAILSCALE_AUTHKEY=

# [OPTIONAL] Internal IP address of the AI server on Tailscale network.
AI_SERVER_IP=

# [OPTIONAL] Port the AI server runs on.
AI_SERVER_PORT=8017

# [OPTIONAL] SOCKS5 proxy used to route traffic to the AI server via Tailscale.
AI_PROXY_ADDRESS=socks5h://localhost:1055


# ── BACKGROUND JOBS (Optional) ────────────────────────────────────────────────

# [OPTIONAL] Enable the high-priority background task processor.
# Set to "true" to enable quiz grading and other background tasks.
ENABLE_HP_JOB=true
