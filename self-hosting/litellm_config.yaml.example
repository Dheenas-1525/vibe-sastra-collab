# ══════════════════════════════════════════════════════════════════════════════
# LiteLLM Proxy Configuration — ViBe Local LLM Setup
#
# HOW TO USE:
#   1. Copy this file to the project root:
#      cp self-hosting/litellm_config.yaml.example litellm_config.yaml
#
#   2. Edit litellm_config.yaml and set the correct api_base for your LM Studio
#
#   3. Uncomment the litellm service in docker-compose.yml
#
#   4. In backend.env, set:
#      ANTHROPIC_BASE_URL=http://litellm:4000
#      ANTHROPIC_CRED=local-llm-no-key-needed
#      ANTHROPIC_MODEL=claude-sonnet-4-20250514
#
# See self-hosting/DEPLOYMENT_GUIDE.md → "1.3 Alternative — Local LLM" for full instructions.
# ══════════════════════════════════════════════════════════════════════════════

model_list:

  # ── Option 1: LM Studio running on the same machine as Docker (most common) ──
  - model_name: claude-sonnet-4-20250514    # Must match ANTHROPIC_MODEL in backend.env
    litellm_params:
      model: openai/lm_studio_local
      # host.docker.internal reaches the Docker host (where LM Studio runs)
      # Works on: macOS, Windows, Linux (with extra_hosts in docker-compose.yml)
      api_base: http://host.docker.internal:1234/v1
      api_key: not-needed

  # ── Option 2: LM Studio running on a different server ────────────────────────
  # Uncomment below and comment out Option 1 if LM Studio is on another machine
  #
  # - model_name: claude-sonnet-4-20250514
  #   litellm_params:
  #     model: openai/lm_studio_remote
  #     api_base: http://YOUR_LM_STUDIO_SERVER_IP:1234/v1
  #     api_key: not-needed

  # ── Option 3: Ollama (alternative to LM Studio) ──────────────────────────────
  # Uncomment if you prefer Ollama over LM Studio
  #
  # - model_name: claude-sonnet-4-20250514
  #   litellm_params:
  #     model: ollama/llama3.1:8b
  #     api_base: http://host.docker.internal:11434

litellm_settings:
  drop_params: true        # Silently ignore unsupported Anthropic params
  set_verbose: false       # Set to true for detailed debug logs
  request_timeout: 300     # 5 minutes — local models can be slow; increase if needed
